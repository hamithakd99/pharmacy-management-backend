// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id    Int     @id @default(autoincrement())
  createdAt DateTime @default(now())
  userId String @unique
  firstName  String
  lastName  String
  email String  @unique
  password String
  role Role @default(EMPLOYEE)
  contactNumber String
  nickName String?
  
  addressLine1  String
  addressLine2  String?
  city String
  province Province
  postalCode String?
}

model ExternalUser {
  id    Int     @id @default(autoincrement())
  userId String @unique
  firstName  String
  lastName  String
  email String  @unique
  role ExternalUserRole @default(CUSTOMER)
  contactNumber String
  nickName String?
  
  addressLine1  String
  addressLine2  String?
  city String
  province Province
  postalCode String?
  suppliedBatches StockBatch[]

}

model Product {
  id    Int     @id @default(autoincrement())
  
  productId String @unique
  name String


  brand String?
  description String?

  strengthValue Float? //remove optional "?" for development, add it back for production
  strengthUnit StrengthUnit?
  dosageForm DosageForm?

  packSize Int?

  categoryId Int?
  //remove optional "?" for development, add it back for production
  category Category? @relation(fields: [categoryId], references: [id])
  stockBatchItems StockBatchItem[]

  reorderLevel Int @default(10)
  isActive Boolean @default(true)

}

model StockBatch {
  id Int @id @default(autoincrement())

  batchNumber String @unique
  invoiceNumber String @unique
  
  supplierId Int
  supplier ExternalUser @relation(fields: [supplierId], references: [id])

  receivedDate DateTime @default(now())

  invoiceDiscountAmount Float @default(0)

  paymentStatus PaymentStatus @default(PENDING)

  items StockBatchItem[]
  
}

model StockBatchItem {
  id Int @id @default(autoincrement())

  stockBatchId Int
  stockBatch StockBatch @relation(fields: [stockBatchId], references: [id])

  productId Int
  product Product @relation(fields: [productId], references: [id])

  receivedQuantity Int

  buyingPrice Float
  sellingPrice Float

  expiryDate DateTime
  manufacturingDate DateTime?
}

model Category {
  id Int @id @default(autoincrement())
  name String @unique
  products Product[]
}

enum Role {
  EMPLOYEE
  ADMIN
  CASHIER
  
}

enum Province {
  WESTERN
  CENTRAL
  SOUTHERN
  NORTHERN
  EASTERN
  NORTH_WESTERN
  NORTH_CENTRAL
  UVA
  SABARAGAMUWA
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

enum ExternalUserRole {
  CUSTOMER
  SUPPLIER
}

enum StrengthUnit {
  MG
  ML
  G
}

enum DosageForm {
  TABLET
  CAPSULE
  SYRUP
  INJECTION
  CREAM
  OINTMENT
  DROPS
}